# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Groq API Key (required) — get free key from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LangSmith (optional — for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=smart-city-commute-planner

# MLflow (optional — for experiment tracking)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=commute-planner

# DeepEval (optional — for evaluation)
DEEPEVAL_API_KEY=your_deepeval_api_key_here

# ChromaDB settings
CHROMA_PERSIST_DIR=./chroma_db

# App settings
APP_ENV=development
LOG_LEVEL=INFO

# Corporate SSL proxy — set to false if behind an SSL-inspection firewall
SSL_VERIFY=true
